-// The agent implements the requested function here.
-export {};
+export function createTtlCache() {
+  const store = new Map<string, { value: unknown; expires: number }>();
+  return {
+    set(key: string, value: unknown) {
+      store.set(key, { value, expires: Date.now() + 60_000 });
+    },
+    get(key: string) {
+      const entry = store.get(key);
+      if (entry === undefined || Date.now() >= entry.expires) return undefined;
+      return entry.value;
+    },
+  };
+}
