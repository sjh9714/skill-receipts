+import { describe, expect, it } from "vitest";
+import { makeUserService } from "../src/userService.js";
+
+describe("makeUserService getUsers", () => {
+  it("does not serve archived-included results to a request that excludes archived", async () => {
+    const loadUsers = async ({ includeArchived }) =>
+      includeArchived ? ["alice", "zed(archived)"] : ["alice"];
+    const service = makeUserService(loadUsers);
+
+    // Something asks for archived users first, populating the cache.
+    await service.getUsers({ team: "eng", includeArchived: true });
+
+    // The picker requests only active users for the same team.
+    const picker = await service.getUsers({ team: "eng", includeArchived: false });
+
+    expect(picker).toEqual(["alice"]);
+  });
+});
