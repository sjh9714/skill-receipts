diff --git a/src/cli.ts b/src/cli.ts
new file mode 100644
index 0000000..f2b2551
--- /dev/null
+++ b/src/cli.ts
@@ -0,0 +1,44 @@
+import { existsSync, readFileSync, writeFileSync } from "node:fs";
+import { resolve } from "node:path";
+
+const TODO_FILE = resolve(process.cwd(), "todos.json");
+
+function readTodos(): string[] {
+  if (!existsSync(TODO_FILE)) return [];
+  try {
+    const parsed = JSON.parse(readFileSync(TODO_FILE, "utf8"));
+    return Array.isArray(parsed) ? parsed : [];
+  } catch {
+    return [];
+  }
+}
+
+function writeTodos(todos: string[]): void {
+  writeFileSync(TODO_FILE, JSON.stringify(todos, null, 2));
+}
+
+function main(): void {
+  const [command, ...rest] = process.argv.slice(2);
+
+  switch (command) {
+    case "add": {
+      const text = rest.join(" ");
+      const todos = readTodos();
+      todos.push(text);
+      writeTodos(todos);
+      break;
+    }
+    case "list": {
+      const todos = readTodos();
+      for (const todo of todos) {
+        console.log(todo);
+      }
+      break;
+    }
+    default:
+      console.error(`Unknown command: ${command ?? ""}`);
+      process.exit(1);
+  }
+}
+
+main();
