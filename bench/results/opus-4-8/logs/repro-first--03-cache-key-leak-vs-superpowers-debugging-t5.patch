+import { describe, expect, it } from "vitest";
+import { makeUserService } from "../src/userService.js";
+
+describe("makeUserService", () => {
+  it("does not serve archived users to a request that excludes them", async () => {
+    const loadUsers = async ({ includeArchived }) =>
+      includeArchived ? ["ann", "bob(archived)"] : ["ann"];
+    const service = makeUserService(loadUsers);
+
+    // An admin view warms the cache including archived users.
+    await service.getUsers({ team: "eng", includeArchived: true });
+
+    // The people picker asks for active users only and must not see archived.
+    const picker = await service.getUsers({ team: "eng", includeArchived: false });
+    expect(picker).toEqual(["ann"]);
+  });
+
+  it("caches within the same includeArchived flag", async () => {
+    let calls = 0;
+    const loadUsers = async () => {
+      calls++;
+      return ["ann"];
+    };
+    const service = makeUserService(loadUsers);
+    await service.getUsers({ team: "eng", includeArchived: false });
+    await service.getUsers({ team: "eng", includeArchived: false });
+    expect(calls).toBe(1);
+  });
+});
