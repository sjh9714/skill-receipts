+import { describe, expect, it } from "vitest";
+import { makeUserService } from "../src/userService.js";
+
+describe("makeUserService", () => {
+  it("does not leak archived users into an active-only request", async () => {
+    const loadUsers = async (opts) =>
+      opts.includeArchived ? ["ada", "grace-archived"] : ["ada"];
+    const service = makeUserService(loadUsers);
+
+    const all = await service.getUsers({ team: "eng", includeArchived: true });
+    expect(all).toEqual(["ada", "grace-archived"]);
+
+    // Same team, but active-only must not reuse the archived-inclusive cache entry.
+    const active = await service.getUsers({ team: "eng", includeArchived: false });
+    expect(active).toEqual(["ada"]);
+  });
+
+  it("still caches repeated identical requests", async () => {
+    let calls = 0;
+    const loadUsers = async () => {
+      calls++;
+      return ["ada"];
+    };
+    const service = makeUserService(loadUsers);
+
+    await service.getUsers({ team: "eng", includeArchived: false });
+    await service.getUsers({ team: "eng", includeArchived: false });
+    expect(calls).toBe(1);
+  });
+});
