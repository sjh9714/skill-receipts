{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CJaLrS3ba5utySs6qghfku","type":"tool_result","content":"1\t// Generic TTL cache with an injectable clock.\n2\texport function createCache(ttlMs, clock = () => Date.now()) {\n3\t  const store = new Map();\n4\t  return {\n5\t    get(key) {\n6\t      const entry = store.get(key);\n7\t      if (!entry || clock() - entry.at > ttlMs) return undefined;\n8\t      return entry.value;\n9\t    },\n10\t    set(key, value) {\n11\t      store.set(key, { value, at: clock() });\n12\t    },\n13\t  };\n14\t}\n15\t"}]},"parent_tool_use_id":null,"session_id":"29b154a4-a59c-4872-ac33-d702244c7eb0","uuid":"cc8e0111-41c2-423c-8ed4-2731f8d34c70","timestamp":"2026-07-22T12:48:24.614Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sungjh/Projects/skill-receipts/bench/.workspaces/repro-first-03-cache-key-leak-off-WQiota/src/cache.js","content":"// Generic TTL cache with an injectable clock.\nexport function createCache(ttlMs, clock = () => Date.now()) {\n  const store = new Map();\n  return {\n    get(key) {\n      const entry = store.get(key);\n      if (!entry || clock() - entry.at > ttlMs) return undefined;\n      return entry.value;\n    },\n    set(key, value) {\n      store.set(key, { value, at: clock() });\n    },\n  };\n}\n","numLines":15,"startLine":1,"totalLines":15}}}
