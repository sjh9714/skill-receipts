+const isoTimestamp = process.argv[2];
+
+// The input is a valid ISO 8601 UTC timestamp, so its ISO string is
+// "YYYY-MM-DDTHH:mm:ss.sssZ". Reuse those UTC fields directly.
+const utcIso = new Date(isoTimestamp).toISOString();
+const date = utcIso.slice(0, 10);
+const time = utcIso.slice(11, 16);
+
+console.log(`${date} ${time}`);
