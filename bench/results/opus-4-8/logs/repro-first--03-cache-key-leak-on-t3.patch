+import { describe, expect, it } from "vitest";
+import { makeUserService } from "../src/userService.js";
+
+describe("getUsers caching", () => {
+  it("does not serve archived-included results to a picker that excludes them", async () => {
+    const loadUsers = async ({ includeArchived }) =>
+      includeArchived ? ["active", "archived"] : ["active"];
+    const service = makeUserService(loadUsers);
+
+    // An admin view fetches the same team WITH archived users first.
+    await service.getUsers({ team: "eng", includeArchived: true });
+
+    // The people picker asks for the same team WITHOUT archived users.
+    const picker = await service.getUsers({ team: "eng", includeArchived: false });
+
+    expect(picker).toEqual(["active"]);
+  });
+});
