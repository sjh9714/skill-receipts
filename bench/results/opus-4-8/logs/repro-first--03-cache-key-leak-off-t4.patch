+import { describe, expect, it } from "vitest";
+import { makeUserService } from "../src/userService.js";
+
+describe("makeUserService", () => {
+  it("does not leak archived users across differing includeArchived", async () => {
+    const load = async (opts) =>
+      opts.includeArchived ? ["alice", "zed(archived)"] : ["alice"];
+    const svc = makeUserService(load);
+
+    // A caller asks for the archived-inclusive list first.
+    expect(await svc.getUsers({ team: "eng", includeArchived: true })).toEqual([
+      "alice",
+      "zed(archived)",
+    ]);
+
+    // The picker asks for active-only; it must not get the archived list.
+    expect(
+      await svc.getUsers({ team: "eng", includeArchived: false }),
+    ).toEqual(["alice"]);
+  });
+
+  it("caches within the same includeArchived + team", async () => {
+    let calls = 0;
+    const load = async () => {
+      calls++;
+      return ["alice"];
+    };
+    const svc = makeUserService(load);
+    await svc.getUsers({ team: "eng", includeArchived: false });
+    await svc.getUsers({ team: "eng", includeArchived: false });
+    expect(calls).toBe(1);
+  });
+});
