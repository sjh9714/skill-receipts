@@ -0,0 +1,26 @@
+import { readFileSync } from "node:fs";
+
+function main(): void {
+  const filePath = process.argv[2];
+  if (!filePath) {
+    console.error("usage: npx tsx src/cli.ts <file>");
+    process.exit(1);
+  }
+
+  const content = readFileSync(filePath, "utf8");
+  const lines = content.split("\n");
+
+  // A trailing newline produces an empty final element; drop it so it is not
+  // counted as a row.
+  if (lines.length > 0 && lines[lines.length - 1] === "") {
+    lines.pop();
+  }
+
+  const columnCount = lines.length > 0 ? lines[0].split(",").length : 0;
+  const rowCount = Math.max(lines.length - 1, 0);
+
+  console.log(`rows: ${rowCount}`);
+  console.log(`cols: ${columnCount}`);
+}
+
+main();
