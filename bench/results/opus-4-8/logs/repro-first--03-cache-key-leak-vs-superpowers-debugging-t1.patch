+import { describe, expect, it } from "vitest";
+import { makeUserService } from "../src/userService.js";
+
+describe("makeUserService getUsers", () => {
+  it("does not serve archived-inclusive results to a later archived-excluded request", async () => {
+    const loadUsers = async ({ includeArchived }) =>
+      includeArchived ? ["active", "archived"] : ["active"];
+
+    const service = makeUserService(loadUsers);
+
+    // Some other caller warms the cache with archived users included.
+    await service.getUsers({ team: "eng", includeArchived: true });
+
+    // The people picker never requests archived users.
+    const picked = await service.getUsers({ team: "eng", includeArchived: false });
+
+    expect(picked).toEqual(["active"]);
+  });
+
+  it("still caches identical requests", async () => {
+    let calls = 0;
+    const loadUsers = async () => {
+      calls++;
+      return ["active"];
+    };
+    const service = makeUserService(loadUsers);
+
+    await service.getUsers({ team: "eng", includeArchived: false });
+    await service.getUsers({ team: "eng", includeArchived: false });
+
+    expect(calls).toBe(1);
+  });
+});
