+import { describe, expect, it } from "vitest";
+import { makeUserService } from "../src/userService.js";
+
+describe("makeUserService", () => {
+  it("does not leak archived users into a request that excludes them", async () => {
+    const loadUsers = async ({ includeArchived }) =>
+      includeArchived ? ["active", "archived"] : ["active"];
+    const service = makeUserService(loadUsers);
+
+    // A caller that wants archived users populates the cache for the team.
+    const withArchived = await service.getUsers({ team: "eng", includeArchived: true });
+    expect(withArchived).toEqual(["active", "archived"]);
+
+    // The people picker requests the same team WITHOUT archived users.
+    const picker = await service.getUsers({ team: "eng", includeArchived: false });
+    expect(picker).toEqual(["active"]);
+  });
+});
